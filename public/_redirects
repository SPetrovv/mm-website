# Vue Router (history mode): serve index.html for client-side routes.
# Stripe success/cancel URLs like /success must not 404 on static hosting.
# Netlify dev + Vite: do not rewrite framework/module/function paths.
/.netlify/*   /.netlify/:splat   200
/@vite/*      /@vite/:splat      200
/src/*        /src/:splat        200
/node_modules/* /node_modules/:splat 200
/*    /index.html   200
